# Logs y temporales
**/*.log
*.log.*

# Archivos del sistema / editores
.DS_Store
Thumbs.db
.vscode/
.idea/

# Certificados y datos sensibles
certs/
*.pem
*.key
*.crt
*.p12

# Carpeta instalador (Inno Setup)
instalador/*
!instalador/instalador.iss