# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.py[cod]

# Entornos virtuales y poetry/pip
.venv/
venv/
env/
*.env
poetry.lock               # opcional: quítalo si NO quieres versionar las dependencias exactas

# Builds y empaquetado
build/
dist/
*.egg-info/
*.egg
